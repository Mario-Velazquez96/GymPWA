# Copia este archivo a .env.local (gitignored) y completa los valores.
# Ambas variables son públicas (anon/publishable key) — NUNCA pongas aquí la
# service key: esa pertenece exclusivamente al repo Gym.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Opcional: credenciales del usuario de pruebas para Playwright (E2E).
E2E_EMAIL=correo@ejemplo.com
E2E_PASSWORD=contraseña-de-prueba
